# Emdash Skills — .env.example
# Every API key referenced anywhere in this repo, with the exact deeplink to obtain it.
# Copy to .env.local (gitignored) and fill in. Source via `set -a; source .env.local; set +a`.
# Required-by-mode is enforced at build time by `bin/check-required-keys.sh <mode>`.

# =============================================================================
# UNIVERSAL BASELINE (every mode requires these)
# =============================================================================

# Anthropic — Claude API for skill execution + agent orchestration
# Get: https://console.anthropic.com/settings/keys  (format: sk-ant-...)
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o vision QA + GPT Image 1.5 + Sora video + DALL-E + Whisper
# Get: https://platform.openai.com/api-keys  (format: sk-...)
OPENAI_API_KEY=

# Cloudflare — Workers/Pages/D1/R2/KV/Queues/Stream deploys + DNS + cache purge
# Global API Key: https://dash.cloudflare.com/profile/api-tokens (37 chars)
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ACCOUNT_ID=
# Scoped token (preferred over global key for CI): same URL, "Create Token"
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# R2 S3-compatible credentials: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Cloudflare Stream (video CDN): https://dash.cloudflare.com/?to=/:account/stream
CF_STREAM_TOKEN=

# GitHub — repo creation, releases, gists, MCP server
# Personal Access Token: https://github.com/settings/tokens  (ghp_... or github_pat_...)
GITHUB_TOKEN=

# Resend — transactional email (every form submission, magic links, receipts)
# Get: https://resend.com/api-keys  (format: re_...)
RESEND_API_KEY=

# Ideogram — logo + favicon synthesis (skill 12 media-orchestration)
# Get: https://developer.ideogram.ai/manage-api-keys
IDEOGRAM_API_KEY=

# =============================================================================
# OBSERVABILITY (auto-provisioned every project — Sentry + PostHog + GA4/GTM)
# =============================================================================

# Sentry — error tracking + performance + Seer auto-fix MCP
# DSN: https://sentry.io/settings/megabyte-labs/projects/<project>/keys/
SENTRY_DSN=
# Auth token (deploy releases, MCP): https://sentry.io/settings/megabyte-labs/auth-tokens/
SENTRY_AUTH_TOKEN=

# PostHog — product analytics + feature flags + session replay (cookie-free)
# Get: https://app.posthog.com/project/settings  (project key + host)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
# Personal API key (for MCP/management): https://app.posthog.com/me/settings
POSTHOG_PERSONAL_API_KEY=

# Google Tag Manager — wraps GA4 + ad pixels + custom events
# Get: https://tagmanager.google.com  (format: GTM-XXXXXXX)
GTM_CONTAINER_ID=
# GA4 direct (when GTM bypassed): https://analytics.google.com/analytics/web/  (G-XXXXXXXXXX)
GA4_MEASUREMENT_ID=

# =============================================================================
# SaaS MODE EXTRAS (auth + billing + workflows + database)
# =============================================================================

# Clerk — authentication, user management, sessions, webhooks
# Get: https://dashboard.clerk.com/last-active?path=api-keys  (pk_test_/sk_test_)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe — subscriptions, checkout, webhooks, billing portal
# Get: https://dashboard.stripe.com/apikeys  (pk_live_/sk_live_)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret: https://dashboard.stripe.com/webhooks  (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Optional: hosted payment link for non-profit/quickstart donations
STRIPE_PAYMENT_LINK_URL=

# Inngest — durable workflows, retries, scheduled jobs
# Get: https://app.inngest.com/env/production/manage/keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Neon — serverless Postgres (when D1 is not enough)
# Get: https://console.neon.tech  (postgresql://user:pass@host/db)
NEON_DATABASE_URL=

# =============================================================================
# PORTFOLIO MODE EXTRAS (stock photo curation for hero/section imagery)
# =============================================================================

# Unsplash — high-res stock photography
# Get: https://unsplash.com/oauth/applications  (Access Key, not Secret)
UNSPLASH_ACCESS_KEY=

# Pexels — free stock photo API (Pexels-first per skill 12 fallback chain)
# Get: https://www.pexels.com/api/new
PEXELS_API_KEY=

# =============================================================================
# LOCAL-BUSINESS MODE EXTRAS (NAP + map + reviews)
# =============================================================================

# Google Maps JavaScript API — embedded map widget
# Get: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# Google Places API — business hours, reviews, photos, NAP enrichment
# Same console as Maps — enable Places API library separately
GOOGLE_PLACES_API_KEY=

# =============================================================================
# MEDIA / AI GENERATION (skill 12 — image, video, voice)
# =============================================================================

# fal.ai — Flux 1.1 Pro Ultra + SDXL + image edit + multi-model gateway
# Get: https://fal.ai/dashboard/keys
FAL_API_KEY=
FAL_AI_API_KEY=

# Recraft — vector + brand-asset generation (skill 12 logo backup)
# Get: https://www.recraft.ai/profile/api
RECRAFT_API_KEY=

# Replicate — open-model API (Flux Schnell, AnimateDiff, Whisper, etc.)
# Get: https://replicate.com/account/api-tokens  (r8_...)
REPLICATE_API_TOKEN=
REPLICATE_API_KEY=

# Runway — Gen-3 Alpha video, image-to-video
# Get: https://app.runwayml.com/account?tab=developer
RUNWAY_API_KEY=

# Luma — Dream Machine video generation
# Get: https://lumalabs.ai/dream-machine/api/keys
LUMA_API_KEY=

# Stability — Stable Diffusion (SDXL, SD3, control nets)
# Get: https://platform.stability.ai/account/keys  (sk-...)
STABILITY_API_KEY=

# HeyGen — talking-head explainer videos (NotebookLM pipeline)
# Get: https://app.heygen.com/settings/api  (also: https://app.heygen.com/avatars)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Synthesia — corporate video avatars (alt to HeyGen)
# Get: https://app.synthesia.io/#/account/api
SYNTHESIA_API_KEY=

# Tavus — personalized AI video (1-1 outreach)
# Get: https://platform.tavus.io/api-keys
TAVUS_API_KEY=

# ElevenLabs — TTS for podcast (NotebookLM pipeline) + voice clones
# Get: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_HOST_A=
ELEVENLABS_VOICE_HOST_B=

# Cloudinary — media optimization + transformation CDN (alt to R2+CF Images)
# Get: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# SEARCH + SCRAPE (skill 03 research, skill 15 source-site rebuild)
# =============================================================================

# Firecrawl — deep crawl with JS rendering (Squarespace/dynamic source-site rebuild)
# Get: https://www.firecrawl.dev/app/api-keys  (fc-...)
FIRECRAWL_API_KEY=

# Tavily — LLM-tuned web search with citation tracking
# Get: https://app.tavily.com/home  (tvly-...)
TAVILY_API_KEY=

# Perplexity — sourced web answers (skill 14 evidence pipeline)
# Get: https://www.perplexity.ai/settings/api  (pplx-...)
PERPLEXITY_API_KEY=

# Google Custom Search Engine (alt to Tavily for free-tier searches)
# Engine ID + API key: https://programmablesearchengine.google.com/controlpanel/all
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ID=

# =============================================================================
# ALTERNATIVE LLM PROVIDERS (fallbacks + specialty)
# =============================================================================

# Google Gemini (Gemini Pro, Gemini Flash via AI Studio)
# Get: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq — fastest Llama 3 + Mixtral inference
# Get: https://console.groq.com/keys  (gsk_...)
GROQ_API_KEY=

# Cohere — embed + rerank + classify
# Get: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Mistral — Mistral Large + Codestral
# Get: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Together AI — open-model gateway
# Get: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# DeepSeek — coder + chat models
# Get: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# =============================================================================
# ANTI-BOT / SECURITY
# =============================================================================

# Cloudflare Turnstile — invisible CAPTCHA on every form (replaces hCaptcha)
# Get: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# =============================================================================
# COMMS / SOCIAL / NOTIFICATIONS
# =============================================================================

# Slack — workspace bot, webhook notifications, MCP server
# OAuth tokens: https://api.slack.com/apps  → your app → "OAuth & Permissions"
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_API_TOKEN=
SLACK_CLIENT_ID=
# Incoming webhook (simpler): same console → "Incoming Webhooks"
SLACK_WEBHOOK_URL=

# Discord — server bot + webhook
# Bot token: https://discord.com/developers/applications  → bot tab
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Webhook URL (per channel): channel settings → integrations → webhooks
DISCORD_WEBHOOK_URL=

# Twilio — SMS (booking confirmations, 2FA, AI hotline 2626)
# Get: https://console.twilio.com/  → Account SID + Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# X / Twitter — API v2 for posting + read
# Get: https://developer.x.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_BEARER_TOKEN=

# Reddit — post + read API
# Get: https://www.reddit.com/prefs/apps  → "create another app"
REDDIT_APP_ID=

# YouTube Data API v3 — channel/playlist/video metadata
# Get: https://console.cloud.google.com/apis/credentials  (enable YouTube Data API)
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_ID=

# Facebook / Pinterest OAuth (publishing)
# FB: https://developers.facebook.com/apps  | Pinterest: https://developers.pinterest.com/apps/
FACEBOOK_OAUTH_ID=
PINTEREST_OAUTH_ID=

# =============================================================================
# EMAIL ALTERNATIVES (Resend is primary)
# =============================================================================

# SendGrid (alt transactional)
# Get: https://app.sendgrid.com/settings/api_keys  (SG...)
SENDGRID_API_KEY=

# Postmark (alt transactional, very fast)
# Get: https://account.postmarkapp.com/api_tokens
POSTMARK_SERVER_TOKEN=

# =============================================================================
# AWS (S3 backups, SES fallback, Bedrock LLM access)
# =============================================================================

# Get: https://console.aws.amazon.com/iam/home#/users  → security credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# APPLE PODCASTS (NotebookLM podcast distribution)
# =============================================================================

# Get: https://podcastsconnect.apple.com  → "API Keys"
APPLE_PODCAST_KEY_ID=
APPLE_PODCAST_PRIVATE_KEY=

# =============================================================================
# CMS / WORKFLOW / AUTOMATION
# =============================================================================

# Notion — docs + DB sync (MCP server)
# Get: https://www.notion.so/my-integrations
NOTION_TOKEN=

# n8n — self-hosted workflow automation (Coolify-deployed)
# Get: your n8n instance → settings → API
N8N_API_KEY=

# Zapier — webhook-only is sufficient for most outbound triggers
# Get: https://zapier.com  → create zap → webhook by zapier
ZAPIER_WEBHOOK_URL=

# =============================================================================
# VOICE / WEARABLE
# =============================================================================

# Picovoice — Eagle speaker biometrics (skill 07 picovoice-eagle-biometric.md)
# Get: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=

# Omi wearable — personal AI device API + MCP
# Get: https://omi.me  → developer settings
OMI_DEV_KEY=
OMI_MCP_KEY=

# =============================================================================
# GIT PLATFORMS (alt providers)
# =============================================================================

# GitHub gist-only token (lower scope)
GITHUB_GIST_TOKEN=
GITHUB_READ_TOKEN=

# GitLab (when not on GitHub)
# Get: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=
GITLAB_READ_TOKEN=

# =============================================================================
# RUNTIME / BUILD ONLY (set per-project, not in shared .env)
# =============================================================================
# PROD_URL=                # Playwright base URL for E2E
# CLAUDE_ENV_FILE=         # Override env file path for skills
# OPENAI_DAILY_BUDGET=     # Soft daily spend cap for OpenAI calls
# SENTRY_RELEASE=          # Release tag for deploy tracking (auto-set in CI)
# CF_PAGES_BRANCH=         # Cloudflare Pages CI context (auto-set)
# CF_PAGES_COMMIT_SHA=     # Cloudflare Pages CI context (auto-set)
