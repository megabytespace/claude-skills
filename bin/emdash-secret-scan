#!/bin/bash
# Scan for hardcoded secrets in staged files
command -v detect-secrets >/dev/null 2>&1 || { echo "Install: pip3 install detect-secrets"; exit 1; }
detect-secrets scan --list-all-plugins 2>/dev/null || pip3 install detect-secrets -q
detect-secrets scan $(git diff --cached --name-only 2>/dev/null | tr '\n' ' ') 2>/dev/null | python3 -c "
import sys,json
d=json.load(sys.stdin)
results=d.get('results',{})
total=sum(len(v) for v in results.values())
if total:
    print(f'WARNING: {total} potential secrets found:')
    for f,secrets in results.items():
        for s in secrets:
            print(f'  {f}:{s[\"line_number\"]} — {s[\"type\"]}')
else:
    print('No secrets detected.')
"
